# Server
PORT=3000
NODE_ENV=development

# Database — SESUAIKAN dengan konfigurasi MySQL Anda
DB_HOST=localhost
DB_PORT=3306
DB_NAME=disaster_dashboard
DB_USER=root
DB_PASSWORD=

# Sync Model (HANYA aktifkan saat onboarding pertama kali, lalu matikan!)
DB_SYNC_DEV=true

# JWT
JWT_SECRET=disaster_dashboard_secret_key_2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=disaster_dashboard_refresh_key_2026
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=disaster_cookie_secret_2026

# CORS
CLIENT_URL=http://localhost:5173

