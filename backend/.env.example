# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=disaster_dashboard
DB_USER=root
DB_PASSWORD=your_password

# Sync Model — Set ke 'true' HANYA untuk onboarding pertama, lalu ganti ke false
DB_SYNC_DEV=false

# JWT — GANTI di production!
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=your_cookie_secret_change_this_in_production

# CORS
CLIENT_URL=http://localhost:5173

